#!/usr/bin/env python3

"""
Microsoft LINK-80 REL to Intel HEX Converter (MSB-first, proper segments)


Usage: python rel2hex input.rel output.hex

This is an experimental script that I wrote with the help of deepseek.
I provided the format specification below, wozmon.rel, and wozmon.hex
and the AI needed just two iterations to complete this python program.

---

https://www.seasip.info/Cpm/rel.html

Microsoft REL file format
The REL format is generated by Microsoft's M80 and Digital Research's RMAC. The following description is from the Digital Research Programmer's Utilities Guide for CP/M+; comments in brackets refer to RMAC syntax.

REL files contain information encoded in a bit stream, which LINK-80 interprets as follows:

If the first bit is a 0, then the next 8 bits are loaded according to the value of the location counter.
If the first bit is a 1, then the next 2 bits are interpreted as follows:
00
special link item, defined below.
01
program relative. The next 16 bits are loaded after being offset by the program segment origin.
10
data relative. The next 16 bits are loaded after being offset by the data segment origin.
11
common relative. The next 16 bits are loaded after being offset by the origin of the currently selected common block.
Special link items
A special item consists of:

A 4-bit control field that selects one of 16 special link items described below.
An optional value field that consists of a 2-bit address [type] field and a 16-bit address field. The address type field is interpreted as follows:
00
absolute
01
program relative
10
data relative
11
common relative
An optional name field that consists of a 3-bit name count followed by the name in 8-bit ASCII characters.
The following special items are followed by a name field only:

0000
entry symbol. The symbol indicated in the name field is defined in this module, so the module should be linked if the current file is being searched, as indicated by the S switch. [PUBLIC declaration]
0001
select common block. Instructs LINK-80 to use the location counter associated with the common block indicated in the name field for subsequent common relative items.
0010
program name. The name of the relocatable module.
0011
unused.
0100
unused.
The following special items are followed by a value field and a name field.

0101
define common size. The value field determines the amount of memory reserved for the common block described in the name field. The first size allocated to a given block must be larger than or equal to any subsequent definitions for that block in other modules being linked.
0110
chain external. The value field contains the head of a chain that ends with an absolute 0. Each element of the chain is replaced with the value of the external symbol described in the name field. [used by EXTRN etc]
0111
define entry point. The value of the symbol in the name field is defined by the value field. [PUBLIC definition]
1000
unused.
The following special items are followed by a value field only.

1001
external plus offset. The following two bytes in the current segment must be offset by the value of the value field after all chains have been processed.
1010
define data size. The value field contains the number of bytes in the data segment of the current module.
1011
set location counter. Set the location counter to the value determined by the value field.
1100
chain address. The value field contains the head of a chain that ends with an absolute 0. Each element of the chain is replaced with the current value of the location counter.
1101
define program size. The value field contains the number of bytes in the program segment of the current module.
1110
end module. Defines the end of the current module. If the value field contains a value other than absolute 0, it is used as the start address for the module being linked. That is, the current module is the main module. The next item in the file starts at the next byte boundary.
1111
end file; has no value field or name field. This item follows the end module item in the last module in the file.

"""


import sys


class BitReader:
    """Reads bits MSB first from a byte stream."""
    def __init__(self, data: bytes):
        self.data = data
        self.byte_pos = 0
        self.bit_pos = 7

    def read_bit(self) -> int:
        if self.byte_pos >= len(self.data):
            raise EOFError()
        bit = (self.data[self.byte_pos] >> self.bit_pos) & 1
        self.bit_pos -= 1
        if self.bit_pos < 0:
            self.byte_pos += 1
            self.bit_pos = 7
        return bit

    def read_bits(self, n: int) -> int:
        val = 0
        for _ in range(n):
            val = (val << 1) | self.read_bit()
        return val

    def read_byte(self) -> int:
        return self.read_bits(8)

    def read_word(self) -> int:
        lo = self.read_byte()
        hi = self.read_byte()
        return lo | (hi << 8)

    def align_to_byte(self):
        if self.bit_pos != 7:
            self.byte_pos += 1
            self.bit_pos = 7


class Segment:
    def __init__(self, name: str):
        self.name = name
        self.base = 0           # starting address (set by ORG)
        self.data = bytearray()
        self.lc = 0             # offset from base

    def set_org(self, addr: int):
        """Set the base address for this segment."""
        self.base = addr
        self.lc = 0

    def emit_byte(self, value: int):
        while len(self.data) <= self.lc:
            self.data.append(0)
        self.data[self.lc] = value & 0xFF
        self.lc += 1

    def emit_word(self, value: int):
        self.emit_byte(value & 0xFF)
        self.emit_byte((value >> 8) & 0xFF)

    @property
    def absolute_start(self) -> int:
        """The absolute address of the first byte in the segment."""
        return self.base


class Link80RelToHex:
    SEG_SPECIAL  = 0
    SEG_PROGRAM  = 1
    SEG_DATA     = 2
    SEG_COMMON   = 3

    CTL_ENTRY_SYMBOL      = 0x0
    CTL_SELECT_COMMON     = 0x1
    CTL_PROGRAM_NAME      = 0x2
    CTL_DEFINE_COMMON     = 0x5
    CTL_CHAIN_EXTERNAL    = 0x6
    CTL_DEFINE_ENTRY      = 0x7
    CTL_EXTERNAL_OFFSET   = 0x9
    CTL_DEFINE_DATA_SIZE  = 0xA
    CTL_SET_LOCATION      = 0xB
    CTL_CHAIN_ADDRESS     = 0xC
    CTL_DEFINE_PROG_SIZE  = 0xD
    CTL_END_MODULE        = 0xE
    CTL_END_FILE          = 0xF

    ADDR_ABSOLUTE = 0
    ADDR_PROGRAM  = 1
    ADDR_DATA     = 2
    ADDR_COMMON   = 3

    def __init__(self):
        self.absolute = Segment("absolute")
        self.program  = Segment("program")
        self.data_seg = Segment("data")
        self.common_blocks = {}
        self.current_segment = self.absolute
        self.current_common = None
        self.finished = False
        self.module_name = ""

    def convert(self, input_file: str, output_file: str):
        with open(input_file, 'rb') as f:
            data = f.read()

        bits = BitReader(data)
        try:
            self._process(bits)
        except EOFError:
            pass

        self._write_hex(output_file)

        print(f"Module: {self.module_name}")
        print(f"  absolute: {len(self.absolute.data)} bytes at 0x{self.absolute.base:04X}")
        print(f"  program:  {len(self.program.data)} bytes at 0x{self.program.base:04X}")
        print(f"  data:     {len(self.data_seg.data)} bytes at 0x{self.data_seg.base:04X}")
        for name, seg in self.common_blocks.items():
            print(f"  common '{name}': {len(seg.data)} bytes")

    def _process(self, bits: BitReader):
        while not self.finished:
            try:
                first = bits.read_bit()
            except EOFError:
                break

            if first == 0:
                b = bits.read_byte()
                self.current_segment.emit_byte(b)
            else:
                seg_type = bits.read_bits(2)
                if seg_type == self.SEG_SPECIAL:
                    self._special(bits)
                elif seg_type == self.SEG_PROGRAM:
                    val = bits.read_word()
                    # Program-relative word: the value is relative to program segment base
                    # Store it as an offset from the segment base
                    self.current_segment.emit_word(val)
                elif seg_type == self.SEG_DATA:
                    val = bits.read_word()
                    self.current_segment.emit_word(val)
                elif seg_type == self.SEG_COMMON:
                    val = bits.read_word()
                    self.current_segment.emit_word(val)

    def _special(self, bits: BitReader):
        ctrl = bits.read_bits(4)

        if ctrl == self.CTL_ENTRY_SYMBOL:
            self._read_name(bits)

        elif ctrl == self.CTL_SELECT_COMMON:
            name = self._read_name(bits)
            if name not in self.common_blocks:
                self.common_blocks[name] = Segment(name)
            self.current_common = self.common_blocks[name]
            self.current_segment = self.current_common

        elif ctrl == self.CTL_PROGRAM_NAME:
            self.module_name = self._read_name(bits)

        elif ctrl == self.CTL_DEFINE_COMMON:
            atype, val = self._read_value(bits)
            name = self._read_name(bits)
            if name not in self.common_blocks:
                self.common_blocks[name] = Segment(name)

        elif ctrl == self.CTL_CHAIN_EXTERNAL:
            self._read_value(bits)
            self._read_name(bits)

        elif ctrl == self.CTL_DEFINE_ENTRY:
            self._read_value(bits)
            self._read_name(bits)

        elif ctrl == self.CTL_EXTERNAL_OFFSET:
            self._read_value(bits)

        elif ctrl == self.CTL_DEFINE_DATA_SIZE:
            atype, size = self._read_value(bits)

        elif ctrl == self.CTL_SET_LOCATION:
            atype, addr = self._read_value(bits)
            # The address tells us the new segment AND its base address (ORG)
            if atype == self.ADDR_ABSOLUTE:
                self.current_segment = self.absolute
                self.absolute.set_org(addr)
            elif atype == self.ADDR_PROGRAM:
                self.current_segment = self.program
                self.program.set_org(addr)
            elif atype == self.ADDR_DATA:
                self.current_segment = self.data_seg
                self.data_seg.set_org(addr)
            elif atype == self.ADDR_COMMON:
                if self.current_common:
                    self.current_segment = self.current_common
                if self.current_common:
                    self.current_common.set_org(addr)

        elif ctrl == self.CTL_CHAIN_ADDRESS:
            self._read_value(bits)

        elif ctrl == self.CTL_DEFINE_PROG_SIZE:
            atype, size = self._read_value(bits)

        elif ctrl == self.CTL_END_MODULE:
            self._read_value(bits)
            bits.align_to_byte()
            self.finished = True

        elif ctrl == self.CTL_END_FILE:
            bits.align_to_byte()
            self.finished = True

    def _read_name(self, bits: BitReader) -> str:
        length = bits.read_bits(3)
        if length == 0:
            return ""
        chars = [chr(bits.read_byte()) for _ in range(length)]
        return ''.join(chars)

    def _read_value(self, bits: BitReader):
        atype = bits.read_bits(2)
        val = bits.read_word()
        return atype, val

    def _write_hex(self, filename: str):
        with open(filename, 'w') as f:
            all_segs = [self.absolute, self.program, self.data_seg] + list(self.common_blocks.values())
            for seg in all_segs:
                self._write_segment(f, seg)
            f.write(":00000001FF\n")

    def _write_segment(self, f, seg: Segment):
        data = seg.data
        if not data:
            return

        # The absolute address is base + offset within the segment data
        base = seg.base

        for i in range(0, len(data), 16):
            chunk = data[i:i+16]
            addr = base + i

            record = bytearray()
            record.append(len(chunk))
            record.append((addr >> 8) & 0xFF)
            record.append(addr & 0xFF)
            record.append(0x00)
            record.extend(chunk)
            chk = (-sum(record)) & 0xFF
            record.append(chk)
            f.write(':' + record.hex().upper() + '\n')


def main():
    if len(sys.argv) != 3:
        print("Usage: rel2hex input.rel output.hex")
        sys.exit(1)

    infile = sys.argv[1]
    outfile = sys.argv[2]

    conv = Link80RelToHex()
    try:
        conv.convert(infile, outfile)
        print(f"Successfully wrote {outfile}")
    except Exception as e:
        print(f"Error: {e}")
        import traceback
        traceback.print_exc()
        sys.exit(1)


if __name__ == '__main__':
    main()
