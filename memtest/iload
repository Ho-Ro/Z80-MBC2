#!/usr/bin/env python3
"""
iload.py - Serial loader for text, Intel HEX, WOZ, and binary files.

Features:
- Auto-detect input lines: Intel HEX, WOZ, or plain text
- Binary mode: binary -> Intel HEX or WOZ (start address required)
- Optional WOZ output format (-w / --woz)
- WOZ input: syntax check only, sent verbatim
- Configurable baud rate, delay, line endings
- Optional CTRL-Z EOF (--eof)
- Optional address offset for HEX/WOZ output (--offset)
- WOZ output limited to 16 data bytes per line
- Strips leading ^Z characters from HEX input
"""

import sys
import time
import argparse
import re
import serial
import os

# ---------- Regex patterns ----------
HEX_RE = re.compile(r"^:[0-9A-Fa-f]+$")
WOZ_RE = re.compile(r"^[0-9A-Fa-f]+:\s*(?:[0-9A-Fa-f]{2}\s*)*$")

WOZ_SIZE = 16

# ---------- Intel HEX helpers ----------
def parse_intel_hex(line):
    try:
        raw = bytes.fromhex(line[1:])
    except ValueError:
        return None

    if (sum(raw) & 0xFF) != 0:
        return None

    length = raw[0]
    addr = (raw[1] << 8) | raw[2]
    rectype = raw[3]
    data = raw[4:4 + length]
    return rectype, addr, data

def make_hex_lines(addr, data):
    """Generate Intel HEX lines, splitting into 16-byte chunks."""
    lines = []
    for i in range(0, len(data), 16):
        chunk = data[i:i + 16]
        lines.append(make_hex_line(addr + i, chunk))
    return lines

def make_hex_line(addr, data):
    """Create a single Intel HEX line."""
    ll = len(data)
    rec = [ll, (addr >> 8) & 0xFF, addr & 0xFF, 0x00] + list(data)
    checksum = (-sum(rec)) & 0xFF
    return ":" + "".join(f"{b:02X}" for b in rec) + f"{checksum:02X}"

# ---------- WOZ helpers ----------
def parse_woz(line):
    if not WOZ_RE.match(line):
        return None
    try:
        addr_str, data_str = line.split(":", 1)
        addr = int(addr_str.strip(), 16)
        data = bytes(int(b, 16) for b in data_str.split())
    except ValueError:
        return None
    return addr, data

def make_woz_lines(addr, data, max_bytes=WOZ_SIZE):
    """Generate WOZ format lines, splitting into chunks of max_bytes."""
    lines = []
    for i in range(0, len(data), max_bytes):
        chunk = data[i:i + max_bytes]
        lines.append(make_woz_line(addr + i, chunk))
    return lines

def make_woz_line(addr, data):
    """Create a single WOZ format line."""
    return f"{addr:04X}: " + " ".join(f"{b:02X}" for b in data)

# ---------- Main ----------
def main():
    parser = argparse.ArgumentParser(description="Serial loader (HEX / WOZ / binary)")

    parser.add_argument("textfile", nargs="?", help="Input file (default: stdin)")
    parser.add_argument("-p", "--port", default="/dev/ttyUSB0", help="Serial port")
    parser.add_argument("--baud", type=int, default=115200, help="Baud rate")
    parser.add_argument("-d", "--delay", type=float, default=5, help="Delay (ms)")
    parser.add_argument("-v", "--verbose", action="store_true", help="Verbose output")

    parser.add_argument("-b", "--binary", metavar="ADDR",
                        help="Binary mode: start address (hex required)")
    parser.add_argument("-w", "--woz", action="store_true",
                        help="Output WOZ format instead of Intel HEX")
    parser.add_argument("-o", "--offset", metavar="OFFSET",
                        help="Address offset for HEX/WOZ output (hex, can be negative)")

    parser.add_argument("--eof", action="store_true",
                        help="Send CTRL-Z (0x1A) after transfer")

    group = parser.add_mutually_exclusive_group()
    group.add_argument("-c", "--crlf", action="store_true")
    group.add_argument("-l", "--lf", action="store_true")
    group.add_argument("-r", "--cr", action="store_true")

    args = parser.parse_args()
    delay = args.delay / 1000.0

    if args.crlf: newline = b"\r\n"
    elif args.lf: newline = b"\n"
    elif args.cr: newline = b"\r"
    else: newline = b"\n"

    # Parse offset
    offset = 0
    if args.offset:
        try:
            # Handle negative hex values
            if args.offset.startswith('-'):
                offset = -int(args.offset[1:], 16)
            else:
                offset = int(args.offset, 16)
        except ValueError:
            print("Invalid offset value", file=sys.stderr)
            sys.exit(1)
        if args.verbose:
            print(f"[VERBOSE] Address offset: {offset:#x} ({offset})", file=sys.stderr)

    try:
        ser = serial.Serial(args.port, args.baud, timeout=1, write_timeout=1)
    except serial.SerialException as e:
        print(f"Serial error: {e}", file=sys.stderr)
        sys.exit(1)

    if args.verbose:
        print(f"[VERBOSE] {args.port} @ {args.baud}", file=sys.stderr)

    # ---------- Binary mode ----------
    if args.binary:
        try:
            addr = int(args.binary, 16)
        except ValueError:
            print("Invalid binary start address", file=sys.stderr)
            sys.exit(1)

        data = (open(args.textfile, "rb").read()
                if args.textfile else sys.stdin.buffer.read())

        out_addr = addr + offset

        if args.woz:
            lines = make_woz_lines(out_addr, data, max_bytes=WOZ_SIZE)
        else:
            lines = make_hex_lines(out_addr, data)

        for line in lines:
            ser.write(line.encode() + newline)
            ser.flush()
            if args.verbose:
                print(line)
            time.sleep(delay)

        if not args.woz:
            ser.write(b":00000001FF" + newline)

        if args.eof:
            ser.write(b"\x1A")

        ser.close()
        return

    # ---------- Text / HEX / WOZ input ----------
    infile = open(args.textfile, "rb") if args.textfile else sys.stdin.buffer

    # Read entire content and strip trailing ^Z characters
    content = infile.read()
    z_pos = content.find(b'\x1a')
    if z_pos != -1:
        content = content[:z_pos]
    # Convert back to text lines
    lines = content.decode('latin-1').splitlines(True)

    for lineno, line in enumerate(lines, 1):
        line = line.rstrip("\r\n")

        # Skip empty lines
        if not line:
            continue

        # Intel HEX
        if HEX_RE.match(line):
            if args.verbose:
                print(f"HEX: ", line, file=sys.stderr)
            parsed = parse_intel_hex(line)
            if not parsed:
                print(f"Warning: bad HEX at line {lineno}", file=sys.stderr)
                continue
            rectype, addr, data = parsed
            if rectype == 0x00:
                out_addr = addr + offset
                if args.woz:
                    # Split into WOZ lines with max WOZ_SIZE bytes per line
                    woz_lines = make_woz_lines(out_addr, data, max_bytes=WOZ_SIZE)
                    for woz_line in woz_lines:
                        ser.write(woz_line.encode(errors="replace") + newline)
                        ser.flush()
                        if args.verbose:
                            print(woz_line)
                        time.sleep(delay)
                    continue
                else:
                    out = make_hex_line(out_addr, data)
            elif rectype == 0x01 and not args.woz:
                out = line
            else:
                continue

        # WOZ (apply offset if specified)
        elif WOZ_RE.match(line):
            if args.verbose:
                print(f"WOZ: ", line, file=sys.stderr)
            parsed = parse_woz(line)
            if not parsed:
                print(f"Warning: bad WOZ at line {lineno}", file=sys.stderr)
                out = line
            else:
                addr, data = parsed
                if offset != 0 or len(data) > WOZ_SIZE:
                    out_addr = addr + offset
                    # Split into WOZ_SIZE byte chunks if needed
                    woz_lines = make_woz_lines(out_addr, data, max_bytes=WOZ_SIZE)
                    for woz_line in woz_lines:
                        ser.write(woz_line.encode(errors="replace") + newline)
                        ser.flush()
                        if args.verbose:
                            print(woz_line)
                        time.sleep(delay)
                    continue
                else:
                    out = line

        # Plain text
        else:
            if args.verbose:
                print(f"TXT: ", line, file=sys.stderr)
            out = line

        ser.write(out.encode(errors="replace") + newline)
        ser.flush()
        time.sleep(delay)

    if args.eof:
        ser.write(b"\x1A")
        if args.verbose:
            print("[VERBOSE] Sent CTRL-Z (0x1A)", file=sys.stderr)

    ser.close()

if __name__ == "__main__":
    main()
