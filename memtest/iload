#!/usr/bin/env python3
"""
iload.py - Serial loader for text, Intel HEX, WOZ, and binary files.

Features:
- Auto-detect input lines: Intel HEX, WOZ, or plain text
- Binary mode: binary -> Intel HEX or WOZ (start address required)
- Optional WOZ output format (-w / --woz)
- Optional HEX output format (-x / --hex) for WOZ input
- WOZ input: passed through verbatim unless -x is used
- Configurable baud rate, delay, line endings
- Optional CTRL-Z EOF (--eof)
- Optional address offset for HEX/WOZ output (--offset)
- WOZ output limited to 16 data bytes per line
- Strips trailing ^Z characters from input
- Optional stdout output mode (-s / --stdout)
"""

import sys, time, argparse, re, serial, os

HEX_RE = re.compile(r"^:[0-9A-Fa-f]+$")
WOZ_RE = re.compile(r"^[0-9A-Fa-f]+:\s*(?:[0-9A-Fa-f]{2}\s*)*$")
WOZ_SIZE = 16

# ---------- Intel HEX helpers ----------
def parse_intel_hex(line):
    try:
        raw = bytes.fromhex(line[1:])
    except ValueError:
        return None
    if (sum(raw) & 0xFF) != 0:
        return None
    length = raw[0]
    addr = (raw[1] << 8) | raw[2]
    rectype = raw[3]
    data = raw[4:4 + length]
    return rectype, addr, data

def make_hex_lines(addr, data):
    lines = []
    for i in range(0, len(data), 16):
        chunk = data[i:i + 16]
        lines.append(make_hex_line(addr + i, chunk))
    return lines

def make_hex_line(addr, data):
    ll = len(data)
    rec = [ll, (addr >> 8) & 0xFF, addr & 0xFF, 0x00] + list(data)
    checksum = (-sum(rec)) & 0xFF
    return ":" + "".join(f"{b:02X}" for b in rec) + f"{checksum:02X}"

# ---------- WOZ helpers ----------
def parse_woz(line):
    if not WOZ_RE.match(line):
        return None
    try:
        addr_str, data_str = line.split(":", 1)
        addr = int(addr_str.strip(), 16)
        data = bytes(int(b, 16) for b in data_str.split())
    except ValueError:
        return None
    return addr, data

def make_woz_lines(addr, data, max_bytes=WOZ_SIZE):
    lines = []
    for i in range(0, len(data), max_bytes):
        chunk = data[i:i + max_bytes]
        lines.append(make_woz_line(addr + i, chunk))
    return lines

def make_woz_line(addr, data):
    return f"{addr:04X}: " + " ".join(f"{b:02X}" for b in data)

# ---------- Output helper ----------
class OutputWriter:
    def __init__(self, to_stdout=False, ser=None, newline=b"\n"):
        self.to_stdout = to_stdout
        self.ser = ser
        self.newline = newline

    def write(self, data):
        if self.to_stdout:
            if isinstance(data, bytes):
                sys.stdout.buffer.write(data + self.newline)
            else:
                sys.stdout.write(data + self.newline.decode())
            sys.stdout.flush()
        else:
            if self.ser:
                if isinstance(data, str):
                    data = data.encode()
                self.ser.write(data + self.newline)
                self.ser.flush()

    def write_raw(self, data):
        if self.to_stdout:
            if isinstance(data, bytes):
                sys.stdout.buffer.write(data)
            else:
                sys.stdout.write(data)
            sys.stdout.flush()
        else:
            if self.ser:
                if isinstance(data, str):
                    data = data.encode()
                self.ser.write(data)
                self.ser.flush()

def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("textfile", nargs="?")
    parser.add_argument("-p", "--port", default="/dev/ttyUSB0")
    parser.add_argument("--baud", type=int, default=115200)
    parser.add_argument("-d", "--delay", type=float, default=5)
    parser.add_argument("-v", "--verbose", action="store_true")
    parser.add_argument("-b", "--binary", metavar="ADDR")
    parser.add_argument("-w", "--woz", action="store_true")
    parser.add_argument("-x", "--hex", action="store_true")
    parser.add_argument("-o", "--offset", metavar="OFFSET")
    parser.add_argument("-s", "--stdout", action="store_true")
    parser.add_argument("--eof", action="store_true")
    group = parser.add_mutually_exclusive_group()
    group.add_argument("-c", "--crlf", action="store_true")
    group.add_argument("-l", "--lf", action="store_true")
    group.add_argument("-r", "--cr", action="store_true")
    args = parser.parse_args()
    delay = args.delay / 1000.0

    if args.crlf: newline = b"\r\n"
    elif args.lf: newline = b"\n"
    elif args.cr: newline = b"\r"
    else: newline = b"\n" if args.stdout else b"\r"

    offset = 0
    if args.offset:
        try:
            offset = int(args.offset, 16) if not args.offset.startswith('-') else -int(args.offset[1:], 16)
        except ValueError:
            print("Invalid offset", file=sys.stderr)
            sys.exit(1)

    output_woz = args.woz and not args.hex
    output_hex = args.hex                     # only true when -x is given

    ser = None
    if not args.stdout:
        try:
            ser = serial.Serial(args.port, args.baud, timeout=1, write_timeout=1)
        except serial.SerialException as e:
            print(f"Serial error: {e}", file=sys.stderr)
            sys.exit(1)
    writer = OutputWriter(to_stdout=args.stdout, ser=ser, newline=newline)

    # ---------- Binary mode ----------
    if args.binary:
        try:
            addr = int(args.binary, 16)
        except ValueError:
            print("Invalid binary start address", file=sys.stderr)
            sys.exit(1)
        data = open(args.textfile, "rb").read() if args.textfile else sys.stdin.buffer.read()
        out_addr = addr + offset
        lines = make_woz_lines(out_addr, data) if output_woz else make_hex_lines(out_addr, data)
        for line in lines:
            writer.write(line)
            if not args.stdout: time.sleep(delay)
        if not output_woz:
            eof = ":00000001FF"
            if args.stdout: sys.stdout.write(eof + newline.decode()); sys.stdout.flush()
            else: ser.write(eof.encode() + newline); ser.flush()
        if args.eof: writer.write_raw(b"\x1A")
        if ser: ser.close()
        return

    # ---------- Text / HEX / WOZ input ----------
    infile = open(args.textfile, "rb") if args.textfile else sys.stdin.buffer
    content = infile.read()
    z_pos = content.find(b'\x1a')
    if z_pos != -1: content = content[:z_pos]
    lines = content.decode('latin-1').splitlines(True)

    eof_sent = False   # track if we already output a HEX EOF record

    for lineno, line in enumerate(lines, 1):
        line = line.rstrip("\r\n")
        if not line: continue

        if HEX_RE.match(line):
            parsed = parse_intel_hex(line)
            if not parsed:
                print(f"Warning: bad HEX at line {lineno}", file=sys.stderr)
                continue
            rectype, addr, data = parsed
            if rectype == 0x00:
                out_addr = addr + offset
                if output_woz:
                    for w in make_woz_lines(out_addr, data):
                        writer.write(w)
                        if not args.stdout: time.sleep(delay)
                    continue
                elif output_hex or offset != 0:
                    out = make_hex_line(out_addr, data)
                else:
                    out = line
            elif rectype == 0x01:
                if output_woz:
                    continue
                out = line
                eof_sent = True     # we are passing through an EOF record
            else:
                continue

        elif WOZ_RE.match(line):
            parsed = parse_woz(line)
            if not parsed:
                if not output_hex:
                    out = line
                else:
                    continue
            else:
                addr, data = parsed
                out_addr = addr + offset
                if output_hex:                     # -x: convert to HEX
                    for h in make_hex_lines(out_addr, data):
                        writer.write(h)
                        if not args.stdout: time.sleep(delay)
                    continue
                elif output_woz:
                    if offset != 0 or len(data) > WOZ_SIZE:
                        for w in make_woz_lines(out_addr, data):
                            writer.write(w)
                            if not args.stdout: time.sleep(delay)
                        continue
                    else:
                        out = line
                else:
                    if offset != 0:
                        out = make_woz_line(out_addr, data)
                    else:
                        out = line

        else:
            out = line

        writer.write(out)
        if not args.stdout: time.sleep(delay)

    # Add HEX EOF only if -x was given and we didn't already output one
    if output_hex and not eof_sent:
        eof = ":00000001FF"
        if args.stdout: sys.stdout.write(eof + newline.decode()); sys.stdout.flush()
        else: ser.write(eof.encode() + newline); ser.flush()

    if args.eof: writer.write_raw(b"\x1A")
    if ser: ser.close()

if __name__ == "__main__":
    main()
